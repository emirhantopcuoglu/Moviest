@model Moviest.Models.ErrorViewModel

<div class="container my-5">
    <h1 class="text-danger">Oops! Bir hata oluştu.</h1>
    <p>@Model.Message</p>

    @if (Model.ShowRequestId)
    {
        <p class="text-muted">Hata Kodu: @Model.RequestId</p>
    }

    @if (!string.IsNullOrEmpty(Model.StackTrace))
    {
        <pre class="bg-light p-3 rounded">@Model.StackTrace</pre>
    }

