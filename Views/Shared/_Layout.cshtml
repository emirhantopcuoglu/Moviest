<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#0b0f1a" />
    <title>@ViewData["Title"] - Moviest</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-icons/1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <nav class="top-navbar">
        <a class="top-nav-brand" asp-controller="Home" asp-action="Index">
            <i class="bi bi-camera-reels-fill"></i> Moviest
        </a>
        <ul class="top-nav-links">
            <li>
                <a class="top-nav-link" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-house-door"></i> Ana Sayfa
                </a>
            </li>
            <li>
                <a class="top-nav-link" asp-controller="Movies" asp-action="Index">
                    <i class="bi bi-film"></i> Filmler
                </a>
            </li>
            @if (User.Identity?.IsAuthenticated == true)
            {
                <li>
                    <a class="top-nav-link" asp-controller="Watchlist" asp-action="Index">
                        <i class="bi bi-bookmark"></i> İzleme Listesi
                    </a>
                </li>
                <li>
                    <a class="top-nav-link" asp-controller="Account" asp-action="Profile">
                        <i class="bi bi-person-circle"></i> @User.Identity.Name
                    </a>
                </li>
                <li>
                    <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                        <button type="submit" class="top-nav-link btn-danger-soft" style="border:none;cursor:pointer;">
                            <i class="bi bi-box-arrow-right"></i> Çıkış
                        </button>
                    </form>
                </li>
            }
            else
            {
                <li>
                    <a class="top-nav-link" asp-controller="Account" asp-action="Login">
                        <i class="bi bi-box-arrow-in-right"></i> Giriş Yap
                    </a>
                </li>
                <li>
                    <a class="btn-accent" asp-controller="Account" asp-action="Register" style="font-size:0.82rem;padding:7px 14px;">
                        Kayıt Ol
                    </a>
                </li>
            }
        </ul>
    </nav>

    <main>
        @RenderBody()
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
