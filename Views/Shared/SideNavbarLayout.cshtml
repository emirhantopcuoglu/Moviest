@using Microsoft.AspNetCore.Identity
@using Moviest.Constants
@inject UserManager<IdentityUser> UserManager
@inject SignInManager<IdentityUser> SignInManager
@{
    var isAuthenticated = User.Identity?.IsAuthenticated == true;
    IdentityUser? currentUser = null;
    var isAdmin = false;

    if (isAuthenticated)
    {
        currentUser = await UserManager.GetUserAsync(User);
        if (currentUser != null)
        {
            isAdmin = await UserManager.IsInRoleAsync(currentUser, Roles.Admin);
        }
    }
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#0b0f1a" />
    <title>@ViewData["Title"] - Moviest</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-icons/1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="/css/sideNavbarLayout.css" asp-append-version="true" />
</head>
<body>

<!-- Mobile toggle -->
<button class="sidebar-toggle" id="sidebarToggle" aria-label="Menüyü aç">
    <i class="bi bi-list"></i>
</button>
<div class="sidebar-overlay" id="sidebarOverlay"></div>

<div class="layout-wrapper">
    <!-- ── Sidebar ── -->
    <nav class="side-navbar" id="sidebar">

        <div class="sidebar-brand">
            <a class="sidebar-brand-name" href="/home" style="text-decoration:none;">
                <i class="bi bi-camera-reels-fill"></i> Moviest
            </a>
            <div class="sidebar-brand-sub">Film dünyasını keşfet</div>
        </div>

        <div class="sidebar-search">
            <form asp-controller="Movies" asp-action="Search" method="get" id="searchForm" autocomplete="off">
                <div class="sidebar-search-wrap" style="position:relative;">
                    <i class="bi bi-search"></i>
                    <input type="text" name="query" id="searchInput" class="sidebar-search-input" placeholder="Film ara..." />
                    <button type="submit" class="sidebar-search-btn"><i class="bi bi-arrow-right"></i></button>
                </div>
                <div class="search-dropdown" id="searchDropdown"></div>
            </form>
        </div>

        <div class="sidebar-nav">
            <div class="sidebar-nav-section">
                <span class="sidebar-nav-label">Keşfet</span>
                <a class="sidebar-nav-link" href="/home">
                    <i class="bi bi-house-door"></i> Ana Sayfa
                </a>
                <a class="sidebar-nav-link" href="/movies/trending">
                    <i class="bi bi-graph-up-arrow"></i> Trend
                </a>
                <a class="sidebar-nav-link" href="/movies/recommendations">
                    <i class="bi bi-stars"></i> Sana Özel
                </a>
                <a class="sidebar-nav-link" href="/movies">
                    <i class="bi bi-fire"></i> Popüler
                </a>
                <a class="sidebar-nav-link" href="/movies/nowplaying">
                    <i class="bi bi-camera-reels"></i> Vizyondakiler
                </a>
                <a class="sidebar-nav-link" href="/movies/topratedmovies">
                    <i class="bi bi-star"></i> En Çok Oylananlar
                </a>
                <a class="sidebar-nav-link" href="/movies/upcomingmovies">
                    <i class="bi bi-hourglass-split"></i> Yakında
                </a>
                <a class="sidebar-nav-link" href="/movies/genres">
                    <i class="bi bi-grid"></i> Kategoriler
                </a>
            </div>

            @if (isAuthenticated)
            {
                <div class="sidebar-nav-section">
                    <span class="sidebar-nav-label">Hesabım</span>
                    <a class="sidebar-nav-link" href="/watchlist">
                        <i class="bi bi-bookmark"></i> İzleme Listesi
                    </a>
                    <a class="sidebar-nav-link" href="/Account/Profile">
                        <i class="bi bi-person-circle"></i> Profilim
                    </a>
                    <a class="sidebar-nav-link" href="/Account/Stats">
                        <i class="bi bi-bar-chart-fill"></i> İstatistiklerim
                    </a>
                    @if (isAdmin)
                    {
                        <a class="sidebar-nav-link" href="/Admin">
                            <i class="bi bi-shield-check"></i> Admin Paneli
                        </a>
                    }
                </div>
            }
        </div>

        <div class="sidebar-footer">
            @if (isAuthenticated)
            {
                <div class="sidebar-user">
                    <div class="sidebar-user-avatar">
                        @((User.Identity?.Name?[..1].ToUpper()) ?? "U")
                    </div>
                    <div style="min-width:0">
                        <div class="sidebar-user-name">@User.Identity?.Name</div>
                        <div class="sidebar-user-role">
                            @(isAdmin ? "Admin" : "Üye")
                        </div>
                    </div>
                </div>
                <form asp-controller="Account" asp-action="Logout" method="post">
                    <button type="submit" class="sidebar-logout-btn">
                        <i class="bi bi-box-arrow-right"></i> Çıkış Yap
                    </button>
                </form>
            }
            else
            {
                <div class="sidebar-auth-links">
                    <a class="sidebar-login-link" href="/Account/Login">
                        <i class="bi bi-box-arrow-in-right"></i> Giriş Yap
                    </a>
                    <a class="sidebar-register-link" href="/Account/Register">
                        <i class="bi bi-person-plus"></i> Kayıt Ol
                    </a>
                </div>
            }
        </div>
    </nav>

    <!-- ── Main Content ── -->
    <main class="main-content">
        @RenderBody()
    </main>
</div>

<form id="__csrf" style="display:none;">@Html.AntiForgeryToken()</form>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
// ── Sidebar toggle ────────────────────────────────────────
const toggle = document.getElementById('sidebarToggle');
const sidebar = document.getElementById('sidebar');
const overlay = document.getElementById('sidebarOverlay');
toggle?.addEventListener('click', () => {
    sidebar.classList.toggle('open');
    overlay.classList.toggle('open');
});
overlay?.addEventListener('click', () => {
    sidebar.classList.remove('open');
    overlay.classList.remove('open');
});
const links = document.querySelectorAll('.sidebar-nav-link');
links.forEach(link => {
    if (link.href === window.location.href) link.classList.add('active');
});

// ── CSRF helper ───────────────────────────────────────────
function getCsrf() {
    return document.querySelector('#__csrf input[name="__RequestVerificationToken"]').value;
}

// ── Toast notifications ───────────────────────────────────
function showToast(msg, type = 'success') {
    const t = document.createElement('div');
    t.className = 'toast-notif toast-' + type;
    t.innerHTML = `<i class="bi bi-${type === 'success' ? 'check-circle-fill' : 'exclamation-circle-fill'}"></i>${msg}`;
    document.body.appendChild(t);
    requestAnimationFrame(() => t.classList.add('show'));
    setTimeout(() => { t.classList.remove('show'); setTimeout(() => t.remove(), 300); }, 2500);
}

// ── Watchlist quick-add (movie card bookmark buttons) ─────
async function quickAdd(btn) {
    if (btn.dataset.loading) return;
    btn.dataset.loading = '1';
    const fd = new FormData();
    fd.append('__RequestVerificationToken', getCsrf());
    fd.append('movieId', btn.dataset.movieId);
    fd.append('movieTitle', btn.dataset.title);
    fd.append('moviePoster', btn.dataset.poster || '');
    fd.append('movieYear', btn.dataset.year || '');
    try {
        const resp = await fetch('/Watchlist/Add', {
            method: 'POST',
            headers: { 'X-Requested-With': 'XMLHttpRequest' },
            body: fd
        });
        if (resp.ok) {
            btn.classList.add('in-list');
            btn.querySelector('i').className = 'bi bi-bookmark-fill';
            btn.title = 'İzleme listesinde';
            showToast('İzleme listesine eklendi.');
        }
    } catch { showToast('Bir hata oluştu.', 'error'); }
    delete btn.dataset.loading;
}

// ── Search autocomplete ───────────────────────────────────
(function() {
    const input = document.getElementById('searchInput');
    const dropdown = document.getElementById('searchDropdown');
    if (!input || !dropdown) return;

    let debounceTimer;

    input.addEventListener('input', () => {
        clearTimeout(debounceTimer);
        const q = input.value.trim();
        if (q.length < 2) { dropdown.style.display = 'none'; return; }
        debounceTimer = setTimeout(() => fetchSuggestions(q), 320);
    });

    input.addEventListener('keydown', e => {
        if (e.key === 'Escape') { dropdown.style.display = 'none'; }
        if (e.key === 'ArrowDown') {
            const first = dropdown.querySelector('.sd-item');
            first?.focus(); e.preventDefault();
        }
    });

    document.addEventListener('click', e => {
        if (!e.target.closest('#searchForm')) dropdown.style.display = 'none';
    });

    async function fetchSuggestions(q) {
        try {
            const resp = await fetch(`/Movies/SearchSuggestions?query=${encodeURIComponent(q)}`);
            const items = await resp.json();
            renderDropdown(items, q);
        } catch { dropdown.style.display = 'none'; }
    }

    function renderDropdown(items, q) {
        if (!items.length) { dropdown.style.display = 'none'; return; }
        dropdown.innerHTML = items.map(m => `
            <a class="sd-item" href="/Movies/Details/${m.id}" tabindex="0">
                <img class="sd-poster" src="${m.poster ? 'https://image.tmdb.org/t/p/w92' + m.poster : 'https://via.placeholder.com/46x69?text=?'}" alt="" loading="lazy" />
                <div class="sd-info">
                    <div class="sd-title">${escHtml(m.title)}</div>
                    <div class="sd-year">${m.year || '—'}</div>
                </div>
            </a>
        `).join('') + `<a class="sd-all" href="/Movies/Search?query=${encodeURIComponent(q)}">
            <i class="bi bi-search"></i> Tüm sonuçları gör
        </a>`;
        dropdown.style.display = 'block';

        dropdown.querySelectorAll('.sd-item').forEach((el, i, arr) => {
            el.addEventListener('keydown', e => {
                if (e.key === 'ArrowDown') { arr[i+1]?.focus(); e.preventDefault(); }
                if (e.key === 'ArrowUp') { i === 0 ? input.focus() : arr[i-1]?.focus(); e.preventDefault(); }
            });
        });
    }

    function escHtml(s) {
        return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }
})();
</script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
