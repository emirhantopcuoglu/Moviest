@model Moviest.Models.ForgotPasswordViewModel
@{
    ViewData["Title"] = "Şifremi Unuttum";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="auth-page">
    <div class="auth-card">
        <span class="auth-logo"><i class="bi bi-envelope-fill"></i> Şifre Sıfırla</span>
        <h1 class="auth-title">Şifreni mi unuttun?</h1>
        <p class="auth-subtitle">Hesabınla ilişkili e-posta adresini gir, sıfırlama bağlantısı gönderelim.</p>

        @if (!ViewData.ModelState.IsValid && ViewData.ModelState[""] != null)
        {
            <div class="alert-app alert-danger-app">
                <i class="bi bi-exclamation-circle-fill"></i>
                @ViewData.ModelState[""]!.Errors.FirstOrDefault()?.ErrorMessage
            </div>
        }

        <form asp-action="ForgotPassword" method="post">
            @Html.AntiForgeryToken()
            <div class="mb-field">
                <label asp-for="Email" class="form-label">E-posta Adresi</label>
                <div class="input-wrap">
                    <i class="bi bi-envelope"></i>
                    <input asp-for="Email" type="email" class="form-control" placeholder="ornek@email.com" autocomplete="email" />
                </div>
                <span asp-validation-for="Email" class="field-error"></span>
            </div>

            <button type="submit" class="btn-accent" style="width:100%;justify-content:center;">
                Sıfırlama Bağlantısı Gönder <i class="bi bi-arrow-right"></i>
            </button>
        </form>

        <div class="auth-footer">
            <a asp-controller="Account" asp-action="Login">
                <i class="bi bi-arrow-left"></i> Giriş sayfasına dön
            </a>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
