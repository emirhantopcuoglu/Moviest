@model Moviest.Models.UserStatsViewModel
@{
    ViewData["Title"] = "İstatistiklerim";
    Layout = "~/Views/Shared/SideNavbarLayout.cshtml";
}

<div class="page-title"><i class="bi bi-bar-chart-fill"></i> İstatistiklerim</div>

@if (Model.TotalInList == 0 && Model.TotalReviews == 0)
{
    <div class="watchlist-empty">
        <i class="bi bi-bar-chart"></i>
        <h3>Henüz istatistik yok</h3>
        <p>Film izleme listene eklemeye ve yorum yazmaya başladıkça burada istatistiklerin görünecek.</p>
        <a href="/movies" class="btn-accent"><i class="bi bi-fire"></i> Film Keşfet</a>
    </div>
}
else
{
    <!-- Stat cards -->
    <div class="stats-grid" style="margin-bottom:2rem;">
        <div class="stat-card">
            <div class="stat-icon stat-icon-blue"><i class="bi bi-collection"></i></div>
            <div>
                <div class="stat-value">@Model.TotalInList</div>
                <div class="stat-label">Listedeki Film</div>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon stat-icon-green"><i class="bi bi-eye-fill"></i></div>
            <div>
                <div class="stat-value">@Model.TotalWatched</div>
                <div class="stat-label">İzlenen</div>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon" style="background:rgba(100,116,139,0.12);color:#64748b;width:46px;height:46px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:1.2rem;flex-shrink:0;">
                <i class="bi bi-eye-slash"></i>
            </div>
            <div>
                <div class="stat-value">@Model.TotalUnwatched</div>
                <div class="stat-label">İzlenmemiş</div>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon stat-icon-gold"><i class="bi bi-star-fill"></i></div>
            <div>
                <div class="stat-value">@Model.TotalRated</div>
                <div class="stat-label">Puanlanan</div>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon stat-icon-gold"><i class="bi bi-graph-up"></i></div>
            <div>
                <div class="stat-value">@(Model.AveragePersonalRating > 0 ? Model.AveragePersonalRating.ToString("F1") : "—")</div>
                <div class="stat-label">Ort. Puan</div>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon stat-icon-blue"><i class="bi bi-chat-quote"></i></div>
            <div>
                <div class="stat-value">@Model.TotalReviews</div>
                <div class="stat-label">Yorum</div>
            </div>
        </div>
    </div>

    <div class="stats-two-col">

        <!-- Rating distribution -->
        @if (Model.TotalRated > 0)
        {
            <div class="card-dark">
                <div class="section-title"><i class="bi bi-bar-chart"></i> Puan Dağılımı</div>
                @{
                    int maxCount = Model.RatingDistribution.Max(b => b.Count);
                }
                <div class="rating-dist">
                    @foreach (var bucket in Model.RatingDistribution.OrderByDescending(b => b.Rating))
                    {
                        double pct = maxCount > 0 ? (double)bucket.Count / maxCount * 100 : 0;
                        string cls = bucket.Rating switch {
                            >= 9 => "rating-high",
                            >= 7 => "rating-good",
                            >= 5 => "rating-avg",
                            >= 4 => "rating-poor",
                            _ => "rating-bad"
                        };
                        <div class="dist-row">
                            <span class="dist-label">@bucket.Rating</span>
                            <div class="dist-bar-wrap">
                                <div class="dist-bar @cls" style="width:@pct.ToString("F0")%"></div>
                            </div>
                            <span class="dist-count">@bucket.Count</span>
                        </div>
                    }
                </div>
            </div>
        }

        <!-- Monthly activity -->
        @if (Model.MonthlyActivity.Any())
        {
            <div class="card-dark">
                <div class="section-title"><i class="bi bi-calendar3"></i> Aylık Aktivite</div>
                @{
                    int maxMonth = Model.MonthlyActivity.Max(b => b.Count);
                }
                <div class="rating-dist">
                    @foreach (var bucket in Model.MonthlyActivity)
                    {
                        double pct = maxMonth > 0 ? (double)bucket.Count / maxMonth * 100 : 0;
                        <div class="dist-row">
                            <span class="dist-label" style="width:58px;font-size:0.71rem;">@bucket.Label</span>
                            <div class="dist-bar-wrap">
                                <div class="dist-bar rating-good" style="width:@pct.ToString("F0")%"></div>
                            </div>
                            <span class="dist-count">@bucket.Count</span>
                        </div>
                    }
                </div>
            </div>
        }
    </div>

    <!-- Recently added -->
    @if (Model.RecentlyAdded.Any())
    {
        <div class="mb-section" style="margin-top:2rem;">
            <div class="section-title"><i class="bi bi-clock-history"></i> Son Eklenenler</div>
            <div class="recent-list">
                @foreach (var item in Model.RecentlyAdded)
                {
                    <a href="@Url.Action("Details", "Movies", new { id = item.MovieId })" class="recent-item">
                        <img src="@(string.IsNullOrEmpty(item.MoviePoster) ? "https://via.placeholder.com/46x69?text=?" : $"https://image.tmdb.org/t/p/w92{item.MoviePoster}")"
                             alt="@item.MovieTitle" loading="lazy" />
                        <div class="recent-info">
                            <div class="recent-title">@item.MovieTitle</div>
                            <div class="recent-meta">
                                @(item.MovieYear ?? "—")
                                @if (item.PersonalRating.HasValue)
                                {
                                    <span class="recent-rating"><i class="bi bi-star-fill"></i> @item.PersonalRating/10</span>
                                }
                                @if (item.IsWatched)
                                {
                                    <span style="color:var(--success);font-size:0.7rem;"><i class="bi bi-eye-fill"></i> İzlendi</span>
                                }
                            </div>
                        </div>
                        <div style="margin-left:auto;font-size:0.7rem;color:var(--text-muted);">
                            @item.AddedAt.ToString("dd MMM")
                        </div>
                    </a>
                }
            </div>
        </div>
    }
}
