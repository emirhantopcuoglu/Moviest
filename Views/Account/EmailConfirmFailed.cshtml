@{
    ViewData["Title"] = "Doğrulama Başarısız";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="auth-wrapper">
    <div class="auth-card" style="text-align:center;">
        <div style="font-size:3rem;margin-bottom:1rem;">❌</div>
        <h1 class="auth-title">Doğrulama Başarısız</h1>
        <p style="color:var(--text-muted);margin-bottom:1rem;">
            E-posta doğrulama bağlantısı geçersiz veya süresi dolmuş.
        </p>
        <p style="color:var(--text-muted);font-size:0.9rem;margin-bottom:1.5rem;">
            Yeniden kayıt olmayı deneyin veya destek ile iletişime geçin.
        </p>
        <a asp-action="Register" asp-controller="Account" class="btn-accent" style="display:inline-block;">
            Tekrar Kayıt Ol
        </a>
    </div>
</div>
