@model Moviest.Models.ChangeEmailViewModel
@{
    ViewData["Title"] = "E-posta Değiştir";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="auth-page">
    <div class="auth-card">
        <span class="auth-logo"><i class="bi bi-envelope-fill"></i> E-posta Değiştir</span>
        <h1 class="auth-title">E-posta adresini güncelle</h1>
        <p class="auth-subtitle">Mevcut e-posta: <strong style="color:var(--text-main);">@ViewBag.CurrentEmail</strong></p>

        @if (!ViewData.ModelState.IsValid && ViewData.ModelState[""] != null)
        {
            <div class="alert-app alert-danger-app">
                <i class="bi bi-exclamation-circle-fill"></i>
                @ViewData.ModelState[""]!.Errors.FirstOrDefault()?.ErrorMessage
            </div>
        }

        <form asp-action="ChangeEmail" method="post">
            @Html.AntiForgeryToken()
            <div class="mb-field">
                <label asp-for="NewEmail" class="form-label">Yeni E-posta Adresi</label>
                <div class="input-wrap">
                    <i class="bi bi-envelope"></i>
                    <input asp-for="NewEmail" type="email" class="form-control" placeholder="yeni@email.com" autocomplete="email" />
                </div>
                <span asp-validation-for="NewEmail" class="field-error"></span>
            </div>

            <div class="mb-field">
                <label asp-for="CurrentPassword" class="form-label">Mevcut Şifre</label>
                <div class="input-wrap">
                    <i class="bi bi-lock"></i>
                    <input asp-for="CurrentPassword" type="password" class="form-control" placeholder="••••••••" autocomplete="current-password" />
                </div>
                <span asp-validation-for="CurrentPassword" class="field-error"></span>
            </div>

            <button type="submit" class="btn-accent" style="width:100%;justify-content:center;">
                E-postayı Güncelle <i class="bi bi-arrow-right"></i>
            </button>
        </form>

        <div class="auth-footer">
            <a asp-controller="Account" asp-action="Profile">
                <i class="bi bi-arrow-left"></i> Profil'e geri dön
            </a>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
