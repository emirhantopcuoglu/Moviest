@{
    ViewData["Title"] = "E-posta Gönderildi";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="auth-page">
    <div class="auth-card" style="text-align:center;">
        <div style="font-size:3rem;margin-bottom:1rem;color:var(--accent);">
            <i class="bi bi-envelope-check-fill"></i>
        </div>
        <h1 class="auth-title">E-posta gönderildi</h1>
        <p class="auth-subtitle" style="margin-bottom:1.5rem;">
            Eğer bu e-posta adresiyle kayıtlı bir hesap varsa, şifre sıfırlama bağlantısı gönderildi.
            Gelen kutunuzu kontrol edin.
        </p>
        <p style="font-size:0.8rem;color:var(--text-muted);margin-bottom:2rem;">
            Bağlantı 1 saat geçerlidir. Spam klasörünü de kontrol etmeyi unutmayın.
        </p>
        <a asp-controller="Account" asp-action="Login" class="btn-accent" style="text-decoration:none;justify-content:center;">
            Giriş Sayfasına Dön <i class="bi bi-arrow-right"></i>
        </a>
    </div>
</div>
