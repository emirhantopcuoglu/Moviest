@model Moviest.Models.ResetPasswordViewModel
@{
    ViewData["Title"] = "Yeni Şifre Belirle";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="auth-page">
    <div class="auth-card">
        <span class="auth-logo"><i class="bi bi-key-fill"></i> Şifre Sıfırla</span>
        <h1 class="auth-title">Yeni şifre belirle</h1>
        <p class="auth-subtitle">Güvenli bir şifre seçin.</p>

        @if (!ViewData.ModelState.IsValid && ViewData.ModelState[""] != null)
        {
            <div class="alert-app alert-danger-app">
                <i class="bi bi-exclamation-circle-fill"></i>
                @ViewData.ModelState[""]!.Errors.FirstOrDefault()?.ErrorMessage
            </div>
        }

        <form asp-action="ResetPassword" method="post">
            @Html.AntiForgeryToken()
            <input asp-for="UserId" type="hidden" />
            <input asp-for="Token" type="hidden" />

            <div class="mb-field">
                <label asp-for="NewPassword" class="form-label">Yeni Şifre</label>
                <div class="input-wrap">
                    <i class="bi bi-lock-fill"></i>
                    <input asp-for="NewPassword" type="password" class="form-control" placeholder="En az 8 karakter, rakam içermeli" autocomplete="new-password" />
                </div>
                <span asp-validation-for="NewPassword" class="field-error"></span>
            </div>

            <div class="mb-field">
                <label asp-for="ConfirmPassword" class="form-label">Yeni Şifre Tekrar</label>
                <div class="input-wrap">
                    <i class="bi bi-lock-fill"></i>
                    <input asp-for="ConfirmPassword" type="password" class="form-control" placeholder="••••••••" autocomplete="new-password" />
                </div>
                <span asp-validation-for="ConfirmPassword" class="field-error"></span>
            </div>

            <button type="submit" class="btn-accent" style="width:100%;justify-content:center;">
                Şifremi Sıfırla <i class="bi bi-arrow-right"></i>
            </button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
