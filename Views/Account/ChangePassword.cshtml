@model Moviest.Models.ChangePasswordViewModel
@{
    ViewData["Title"] = "Şifre Değiştir";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="auth-page">
    <div class="auth-card">
        <span class="auth-logo"><i class="bi bi-key-fill"></i> Şifre Değiştir</span>
        <h1 class="auth-title">Yeni şifre oluştur</h1>
        <p class="auth-subtitle">Güvenli bir şifre seçin.</p>

        @if (!ViewData.ModelState.IsValid && ViewData.ModelState[""] != null)
        {
            <div class="alert-app alert-danger-app">
                <i class="bi bi-exclamation-circle-fill"></i>
                @ViewData.ModelState[""]!.Errors.FirstOrDefault()?.ErrorMessage
            </div>
        }

        <form asp-action="ChangePassword" method="post">
            @Html.AntiForgeryToken()
            <div class="mb-field">
                <label asp-for="CurrentPassword" class="form-label">Mevcut Şifre</label>
                <div class="input-wrap">
                    <i class="bi bi-lock"></i>
                    <input asp-for="CurrentPassword" type="password" class="form-control" placeholder="••••••••" />
                </div>
                <span asp-validation-for="CurrentPassword" class="field-error"></span>
            </div>

            <div class="mb-field">
                <label asp-for="NewPassword" class="form-label">Yeni Şifre</label>
                <div class="input-wrap">
                    <i class="bi bi-lock-fill"></i>
                    <input asp-for="NewPassword" type="password" class="form-control" placeholder="En az 8 karakter, rakam içermeli" />
                </div>
                <span asp-validation-for="NewPassword" class="field-error"></span>
            </div>

            <div class="mb-field">
                <label asp-for="ConfirmNewPassword" class="form-label">Yeni Şifre Tekrar</label>
                <div class="input-wrap">
                    <i class="bi bi-lock-fill"></i>
                    <input asp-for="ConfirmNewPassword" type="password" class="form-control" placeholder="••••••••" />
                </div>
                <span asp-validation-for="ConfirmNewPassword" class="field-error"></span>
            </div>

            <button type="submit" class="btn-accent" style="width:100%;justify-content:center;">
                Şifreyi Güncelle <i class="bi bi-arrow-right"></i>
            </button>
        </form>

        <div class="auth-footer">
            <a asp-controller="Account" asp-action="Profile">
                <i class="bi bi-arrow-left"></i> Profil'e geri dön
            </a>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
