@model Moviest.Models.ActorDetailsViewModel
@{
    ViewData["Title"] = Model.Actor.Name;
    Layout = "~/Views/Shared/SideNavbarLayout.cshtml";
}

<div class="actor-page-header">
    <div class="actor-page-img">
        <img src="@(string.IsNullOrEmpty(Model.Actor.ProfilePath) ? "https://via.placeholder.com/300x450?text=Görsel+Yok" : $"https://image.tmdb.org/t/p/w300{Model.Actor.ProfilePath}")"
             alt="@Model.Actor.Name" />
    </div>
    <div class="actor-page-info">
        <h1 class="actor-page-name">@Model.Actor.Name</h1>

        <div class="actor-meta-row">
            @if (!string.IsNullOrEmpty(Model.Actor.Birthday))
            {
                <span class="actor-meta-item">
                    <i class="bi bi-calendar-heart"></i>
                    @Model.Actor.Birthday
                </span>
            }
            @if (!string.IsNullOrEmpty(Model.Actor.Deathday))
            {
                <span class="actor-meta-item">
                    <i class="bi bi-x-circle"></i>
                    @Model.Actor.Deathday
                </span>
            }
            @if (!string.IsNullOrEmpty(Model.Actor.PlaceOfBirth))
            {
                <span class="actor-meta-item">
                    <i class="bi bi-geo-alt"></i>
                    @Model.Actor.PlaceOfBirth
                </span>
            }
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.Actor.Biography))
        {
            <p class="actor-bio">@Model.Actor.Biography</p>
        }
        else
        {
            <p class="actor-bio" style="color:var(--text-muted);font-style:italic;">
                Bu aktör hakkında Türkçe biyografi bulunamadı.
            </p>
        }
    </div>
</div>

@if (Model.Movies?.Any() == true)
{
    <div class="section-title" style="margin-top:1.5rem;">
        <i class="bi bi-film"></i> Yer Aldığı Filmler (@Model.Movies.Count)
    </div>
    <div class="movie-grid">
        @foreach (var movie in Model.Movies.Where(m => !string.IsNullOrEmpty(m.Poster)).Take(40))
        {
            <div class="movie-card">
                <div class="poster-wrap">
                    <img src="@(string.IsNullOrEmpty(movie.Poster) ? "https://via.placeholder.com/500x750?text=Görsel+Yok" : $"https://image.tmdb.org/t/p/w500{movie.Poster}")"
                         alt="@movie.Title" loading="lazy" />
                    <div class="poster-overlay">
                        <a href="@Url.Action("Details", "Movies", new { id = movie.Id })" class="overlay-btn">Detaylar</a>
                    </div>
                    <button class="card-bookmark-btn"
                            onclick="quickAdd(this)"
                            data-movie-id="@movie.Id"
                            data-title="@movie.Title"
                            data-poster="@(movie.Poster ?? "")"
                            data-year="@(DateTime.TryParse(movie.ReleaseDate, out var abd) ? abd.Year.ToString() : "")"
                            title="İzleme listesine ekle">
                        <i class="bi bi-bookmark-plus"></i>
                    </button>
                </div>
                <div class="card-info">
                    <div class="card-title" title="@movie.Title">@movie.Title</div>
                    <div class="card-year">@(DateTime.TryParse(movie.ReleaseDate, out var d) ? d.ToString("yyyy") : "-")</div>
                    <div class="card-footer-row">
                        <span class="rating-badge @GetRatingClass(movie.VoteAverage)">
                            <i class="bi bi-star-fill"></i> @movie.VoteAverage.ToString("F1")
                        </span>
                    </div>
                </div>
            </div>
        }
    </div>
}

@functions {
    string GetRatingClass(double v) => v switch {
        >= 9 => "rating-high", >= 7 => "rating-good", >= 5 => "rating-avg",
        >= 4 => "rating-poor", > 0 => "rating-bad", _ => "rating-unknown"
    };
}
