@model GenreListResponse
@{
    Layout = "~/Views/Shared/SideNavbarLayout.cshtml";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Film Türleri</title>
</head>
<body>
    <header>
        🎬 Film Türlerini Keşfedin
    </header>

    <div class="container">
        @if (Model?.Genres == null || !Model.Genres.Any())
        {
            <p>Hiçbir tür bulunamadı.</p>
        }
        else
        {
            <div class="genre-grid">
                @foreach (var genre in Model.Genres)
                {
                    <div class="genre-card">

                        <div class="genre-header">
                            <div class="genre-icon">
                                @GetGenreEmoji(genre.Name)
                            </div>
                            @genre.Name
                        </div>

                        <div class="genre-body">
                            <a href="@Url.Action("MoviesByGenre", "Movies", new { id = genre.Id })">
                                Keşfet
                            </a>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</body>
</html>
@functions {
    private string GetGenreEmoji(string genreName)
    {
        return genreName.ToLower() switch
        {
            "aksiyon" => "🔥",
            "komedi" => "😂", 
            "dram" => "🎭", 
            "korku" => "👻", 
            "romantik" => "❤️", 
            "bilim-kurgu" => "🚀", 
            "macera" => "🌍",
            "fantastik" => "🧙‍♂️", 
            "animasyon" => "🎨", 
            "suç" => "🕵️‍♂️", 
            "belgesel" => "📚", 
            "aile" => "👨‍👩‍👧‍👦", 
            "tarih" => "🏰", 
            "müzik" => "🎵", 
            "gizem" => "🕵️‍♀️", 
            "tv film" => "📺", 
            "gerilim" => "😱", 
            "savaş" => "⚔️", 
            "vahşi batı" => "🤠",
            _ => "🎬" 
        };
    }
}
<link href="/css/genres.css" rel="stylesheet">