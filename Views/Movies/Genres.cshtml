@model Moviest.Models.GenreListResponse
@{
    ViewData["Title"] = "Film Kategorileri";
    Layout = "~/Views/Shared/SideNavbarLayout.cshtml";
}

<div class="page-title"><i class="bi bi-grid"></i> Film Kategorileri</div>

@if (Model?.Genres == null || !Model.Genres.Any())
{
    <div class="alert-app alert-info-app">
        <i class="bi bi-info-circle-fill"></i> Kategori bulunamadı.
    </div>
}
else
{
    <div class="genres-grid">
        @foreach (var genre in Model.Genres)
        {
            <a href="@Url.Action("MoviesByGenre", "Movies", new { id = genre.Id })" class="genre-card-item">
                <span class="genre-emoji">@GetGenreEmoji(genre.Name)</span>
                <div class="genre-name">@genre.Name</div>
            </a>
        }
    </div>
}

@functions {
    string GetGenreEmoji(string name) => name?.ToLower() switch {
        "aksiyon"    => "💥",
        "komedi"     => "😂",
        "dram"       => "🎭",
        "korku"      => "👻",
        "romantik"   => "❤️",
        "bilim-kurgu"=> "🚀",
        "macera"     => "🌍",
        "fantastik"  => "🧙",
        "animasyon"  => "🎨",
        "suç"        => "🕵️",
        "belgesel"   => "📚",
        "aile"       => "👨‍👩‍👧",
        "tarih"      => "🏰",
        "müzik"      => "🎵",
        "gizem"      => "🔍",
        "tv film"    => "📺",
        "gerilim"    => "😱",
        "savaş"      => "⚔️",
        "vahşi batı" => "🤠",
        _            => "🎬"
    };
}
