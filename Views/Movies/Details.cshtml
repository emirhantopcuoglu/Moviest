@model MovieDetails
@{
    Layout = "~/Views/Shared/SideNavbarLayout.cshtml";
}
<div class="container my-5">
    <h1 class="text-center mb-4 fw-bold">@Model.Title</h1>

    <div class="row g-4">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-4">
                <img src="@(string.IsNullOrEmpty(Model.Poster) 
                    ? "https://via.placeholder.com/500x750?text=No+Image" 
                    : $"https://image.tmdb.org/t/p/w500{Model.Poster}")" 
                    class="card-img-top rounded-4" alt="@Model.Title">
            </div>
        </div>

        <div class="col-md-8">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body">
                    <div class="mb-3">
                        <h6 class="fw-bold text-muted">Vizyon Tarihi</h6>
                        <p class="fs-5">
                            @(DateTime.TryParse(Model.ReleaseDate, out var parsedDate) 
                                ? parsedDate.ToString("dd/MM/yyyy") 
                                : "-")
                        </p>
                    </div>

                    <div class="mb-3">
                        <span class="rating-tag @GetRatingClass(Model.VoteAverage)">
                            <i class="bi bi-star-fill">
                                @Model.VoteAverage.ToString("F1")
                            </i>
                        </span>
                    </div>

                    <div class="mb-3">
                        <h6 class="fw-bold text-muted">Tür</h6>
                        <div>
                            @if (Model.Genres != null && Model.Genres.Any())
                            {
                                foreach (var genre in Model.Genres)
                                {
                                    <span class="genre-tag">@genre.Name</span>
                                }
                            }
                            else
                            {
                                <span>-</span>
                            }
                        </div>
                    </div>
                    
                    <div class="mt-4">
                        <h4 class="fw-bold">Film Hakkında</h4>
                        <p class="text-muted fs-6">@Model.Overview</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@functions {
    private string GetRatingClass(double vote)
    {
        if (vote >= 9) return "rating-high";
        if (vote >= 7) return "rating-good";
        if (vote >= 5) return "rating-average";
        if (vote >= 4) return "rating-poor";
        return "rating-bad";
    }
}

<link href="/css/details.css" rel="stylesheet">