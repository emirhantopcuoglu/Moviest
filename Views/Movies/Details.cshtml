@model MovieDetails
@{
    Layout = "~/Views/Shared/SideNavbarLayout.cshtml";
}
<link href="~/css/details.css" rel="stylesheet">
<div class="container my-5">
    <h1 class="text-center mb-4 fw-bold">@Model.Title</h1>

    <div class="row g-4">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-4">
                <img src="@(string.IsNullOrEmpty(Model.Poster) 
                    ? "https://via.placeholder.com/500x750?text=No+Image" 
                    : $"https://image.tmdb.org/t/p/w500{Model.Poster}")" 
                    class="card-img-top rounded-4" alt="@Model.Title">
            </div>
        </div>

        <div class="col-md-8">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body">
                    <div class="mb-3">
                        <h6 class="fw-bold text-muted">Vizyon Tarihi</h6>
                        <p class="fs-5">
                            @(DateTime.TryParse(Model.ReleaseDate, out var parsedDate) 
                                ? parsedDate.ToString("dd/MM/yyyy") 
                                : "-")
                        </p>
                    </div>

                    <div class="mb-3">
                        <span class="rating-tag @GetRatingClass(Model.VoteAverage)">
                                @if(Model.VoteAverage == null || Model.VoteAverage == 0)
                                {
                                    <i class="bi bi-star-fill">
                                        -
                                    </i>
                                }
                                else
                                {
                                    <i class="bi bi-star-fill">
                                        @Model.VoteAverage.ToString("F1")
                                    </i> 
                                }  
                        </span>
                    </div>

                    <div class="mb-3">
                        <h4 class="fw-bold">Tür</h6>
                        <div>
                            @if (Model.Genres != null && Model.Genres.Any())
                            {
                                foreach (var genre in Model.Genres)
                                {
                                    <span class="genre-tag">@genre.Name</span>
                                }
                            }
                            else
                            {
                                <span>-</span>
                            }
                        </div>
                    </div>

                    <div class="mb-3">
                        <h4 class="fw-bold">Film Hakkında</h4>
                        <div>
                            @if (Model.Overview != null && Model.Overview.Any())
                            {
                                <p class="text-muted fs-6">@Model.Overview</p>
                            }
                            else
                            {
                                <span>Bu film hakkında bilgi bulunamadı.</span>
                            }
                        </div>
                    </div>

                    <div class="mt-4">
                        <h4 class="fw-bold">Oyuncu Kadrosu</h6>
                        <div>
                            @if (Model.Cast != null && Model.Cast.Any())
                            {
                                foreach (var c in Model.Cast)
                                {
                                    <span class="cast-tag">@c.Name</span>
                                }
                            }
                            else
                            {
                                <span>Oyuncu kadrosu hakkında bilgi bulunamadı.</span>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row mt-5">
        <h4 class="fw-bold mb-3">Fragmanlar</h4>
        @if (Model.Videos != null && Model.Videos.Any())
        {
            <div class="col-12">
                <div class="row g-4">
                    @foreach (var video in Model.Videos)
                    {
                        <div class="col-md-6">
                            <div class="ratio ratio-16x9 shadow-sm rounded-4">
                                <iframe 
                                    src="https://www.youtube.com/embed/@video.Key" 
                                    frameborder="0" 
                                    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" 
                                    allowfullscreen>
                                </iframe>
                            </div>
                            <p class="mt-2 text-center fw-bold">@video.Name</p>
                        </div>
                    }
                </div>
            </div>
        }
        else
        {
            <span>Bu film için fragman bulunamadı.</span>
        }
    </div>
</div>

<div class="row mt-5">
    <h4 class="fw-bold mb-3">Benzer Filmler</h4>
    @if (Model.SimilarMovies != null && Model.SimilarMovies.Any())
    {
        <div class="position-relative">
            <div id="similarMoviesCarousel" class="carousel slide" data-bs-ride="carousel">
                <div class="carousel-inner">
                    @for (int i = 0; i < Model.SimilarMovies.Count; i += 4) // 4 film bir satırda gösterilecek
                    {
                        <div class="carousel-item @(i == 0 ? "active" : "")">
                            <div class="row g-3">
                                @foreach (var movie in Model.SimilarMovies.Skip(i).Take(4))
                                {
                                    <div class="col-md-3">
                                        <div class="card border-0 shadow-sm rounded-4">
                                            <img src="@(string.IsNullOrEmpty(movie.Poster) 
                                                ? "https://via.placeholder.com/500x750?text=No+Image" 
                                                : $"https://image.tmdb.org/t/p/w500{movie.Poster}")" 
                                                class="card-img-top rounded-4" alt="@movie.Title">
                                            <div class="card-body text-center">
                                                <h6 class="card-title text-truncate">@movie.Title</h6>
                                                <a href="@Url.Action("Details", "Movies" , new { id=movie.Id })"
                                            class="btn btn-outline-primary btn-sm rounded-pill">Detaylar</a>
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>
                <button class="carousel-control-prev custom-carousel-control" type="button" data-bs-target="#similarMoviesCarousel" data-bs-slide="prev">
                    <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                    <span class="visually-hidden">Önceki</span>
                </button>
                <button class="carousel-control-next custom-carousel-control" type="button" data-bs-target="#similarMoviesCarousel" data-bs-slide="next">
                    <span class="carousel-control-next-icon" aria-hidden="true"></span>
                    <span class="visually-hidden">Sonraki</span>
                </button>
            </div>
        </div>
    }
    else
    {
        <p class="text-muted">Benzer film bulunamadı.</p>
    }
</div>


@functions {
    private string GetRatingClass(double vote)
    {
        if (vote >= 9) return "rating-high";
        if (vote >= 7) return "rating-good";
        if (vote >= 5) return "rating-average";
        if (vote >= 4) return "rating-poor";
        if (vote == 0) return "unknown";
        return "rating-bad";
    }
}


