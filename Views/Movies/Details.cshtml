@model Moviest.Models.MovieDetails
@{
    ViewData["Title"] = Model.Title;
    Layout = "~/Views/Shared/SideNavbarLayout.cshtml";
}

<div class="details-layout">
    <div class="details-poster-col">
        <img src="@(string.IsNullOrEmpty(Model.Poster) ? "https://via.placeholder.com/500x750?text=Görsel+Yok" : $"https://image.tmdb.org/t/p/w500{Model.Poster}")"
             alt="@Model.Title" />
    </div>

    <div class="details-info-col">
        <h1 class="details-title">@Model.Title</h1>

        <div class="details-meta">
            <div class="details-meta-item">
                <i class="bi bi-calendar3"></i>
                @(DateTime.TryParse(Model.ReleaseDate, out var d) ? d.ToString("dd MMM yyyy") : "-")
            </div>
            @if (Model.VoteAverage > 0)
            {
                <div class="details-meta-item">
                    <span class="rating-badge @GetRatingClass(Model.VoteAverage)">
                        <i class="bi bi-star-fill"></i> @Model.VoteAverage.ToString("F1")
                    </span>
                </div>
            }
        </div>

        <div style="margin-bottom:1rem;display:flex;align-items:center;gap:10px;flex-wrap:wrap;">
            @if (Model.Genres?.Any() == true)
            {
                @foreach (var genre in Model.Genres)
                {
                    <span class="genre-tag">@genre.Name</span>
                }
            }
            <button id="wl-toggle-btn" class="btn-outline-accent" onclick="toggleDetailsWl()" style="margin-left:auto;">
                <i class="bi bi-bookmark" id="wl-icon"></i>
                <span id="wl-text">İzleme Listesine Ekle</span>
            </button>
        </div>

        <div class="section-title"><i class="bi bi-card-text"></i> Film Hakkında</div>
        <p class="details-overview">
            @(string.IsNullOrWhiteSpace(Model.Overview)
                ? "Bu film için Türkçe açıklama bulunamadı."
                : Model.Overview)
        </p>

        @if (Model.Cast?.Any() == true)
        {
            <div class="section-title"><i class="bi bi-people"></i> Oyuncu Kadrosu</div>
            <div class="cast-grid">
                @foreach (var actor in Model.Cast.Take(8))
                {
                    <a href="@Url.Action("ActorDetails", "Movies", new { id = actor.Id })" style="text-decoration:none;">
                        <div class="actor-card">
                            <img src="@(string.IsNullOrEmpty(actor.ProfilePath) ? "https://via.placeholder.com/300x450?text=?" : $"https://image.tmdb.org/t/p/w300{actor.ProfilePath}")"
                                 alt="@actor.Name" loading="lazy" />
                            <div class="actor-card-info">
                                <div class="actor-card-name">@actor.Name</div>
                                <div class="actor-card-char">@actor.Character</div>
                            </div>
                        </div>
                    </a>
                }
            </div>
        }
    </div>
</div>

@if (Model.Videos?.Any() == true)
{
    <div class="mb-section">
        <div class="section-title"><i class="bi bi-play-circle"></i> Fragmanlar</div>
        <div class="trailer-grid">
            @foreach (var video in Model.Videos.Take(4))
            {
                <div>
                    <div class="ratio ratio-16x9" style="border-radius:var(--radius);overflow:hidden;">
                        <iframe src="https://www.youtube.com/embed/@video.Key"
                                title="@video.Name"
                                frameborder="0"
                                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                                allowfullscreen></iframe>
                    </div>
                    <p class="trailer-label">@video.Name</p>
                </div>
            }
        </div>
    </div>
}

@if (Model.SimilarMovies?.Any() == true)
{
    <div class="mb-section">
        <div class="section-title"><i class="bi bi-collection"></i> Benzer Filmler</div>
        <div class="similar-grid">
            @foreach (var movie in Model.SimilarMovies.Take(12))
            {
                <div class="movie-card">
                    <div class="poster-wrap">
                        <img src="@(string.IsNullOrEmpty(movie.Poster) ? "https://via.placeholder.com/500x750?text=Görsel+Yok" : $"https://image.tmdb.org/t/p/w342{movie.Poster}")"
                             alt="@movie.Title" loading="lazy" />
                        <div class="poster-overlay">
                            <a href="@Url.Action("Details", "Movies", new { id = movie.Id })" class="overlay-btn">Detaylar</a>
                        </div>
                    </div>
                    <div class="card-info">
                        <div class="card-title" title="@movie.Title">@movie.Title</div>
                        <div class="card-year">@(DateTime.TryParse(movie.ReleaseDate, out var y) ? y.ToString("yyyy") : "-")</div>
                        <div class="card-footer-row">
                            <span class="rating-badge @GetRatingClass(movie.VoteAverage)">
                                <i class="bi bi-star-fill"></i> @movie.VoteAverage.ToString("F1")
                            </span>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
}

@{
    var userReview = ViewBag.UserReview as Moviest.Models.Review;
    var otherReviews = (ViewBag.OtherReviews as List<Moviest.Models.Review>) ?? new List<Moviest.Models.Review>();
    int reviewCount = ViewBag.ReviewCount ?? 0;
}

<div class="mb-section">
    <div class="section-title">
        <i class="bi bi-chat-quote"></i> Yorumlar
        @if (reviewCount > 0)
        {
            <span class="review-count-badge">@reviewCount</span>
        }
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert-app alert-success-app" style="margin-bottom:1rem;">
            <i class="bi bi-check-circle-fill"></i> @TempData["Success"]
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert-app alert-danger-app" style="margin-bottom:1rem;">
            <i class="bi bi-exclamation-circle-fill"></i> @TempData["Error"]
        </div>
    }

    @if (userReview == null)
    {
        <div class="review-form-card">
            <div style="font-size:0.82rem;font-weight:600;color:var(--text-secondary);margin-bottom:0.75rem;letter-spacing:0.04em;text-transform:uppercase;">
                <i class="bi bi-pencil-square" style="color:var(--accent);"></i> Yorumunuzu Yazın
            </div>
            <form asp-controller="Reviews" asp-action="Add" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="MovieId" value="@Model.Id" />
                <input type="hidden" name="MovieTitle" value="@Model.Title" />
                <div class="review-form-row">
                    <div style="flex:1;">
                        <textarea name="Content" class="form-control review-textarea"
                                  placeholder="Bu film hakkında düşüncelerinizi paylaşın..." maxlength="1000" rows="3"></textarea>
                    </div>
                    <div class="review-rating-col">
                        <label class="form-label">Puanınız</label>
                        <select name="Rating" class="form-select review-rating-select">
                            @for (int i = 10; i >= 1; i--)
                            {
                                <option value="@i">@i / 10</option>
                            }
                        </select>
                        <button type="submit" class="btn-accent" style="width:100%;margin-top:8px;">
                            <i class="bi bi-send"></i> Gönder
                        </button>
                    </div>
                </div>
            </form>
        </div>
    }
    else
    {
        <div class="review-card review-card-own">
            <div class="review-card-header">
                <div class="review-avatar">@userReview.UserName[..1].ToUpper()</div>
                <div>
                    <div class="review-username">@userReview.UserName <span class="review-own-tag">Sen</span></div>
                    <div class="review-date">@userReview.CreatedAt.ToString("dd MMM yyyy")</div>
                </div>
                <div class="review-rating-badge @GetRatingClass(userReview.Rating)">
                    <i class="bi bi-star-fill"></i> @userReview.Rating/10
                </div>
                <form asp-controller="Reviews" asp-action="Delete" method="post" style="margin-left:auto;">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@userReview.Id" />
                    <button type="submit" class="btn-danger-soft" style="padding:5px 10px;font-size:0.74rem;"
                            onclick="return confirm('Yorumunuz silinecek. Emin misiniz?')">
                        <i class="bi bi-trash3"></i> Sil
                    </button>
                </form>
            </div>
            <p class="review-content">@userReview.Content</p>
        </div>
    }

    @if (otherReviews.Any())
    {
        <div class="review-list">
            @foreach (var review in otherReviews)
            {
                <div class="review-card">
                    <div class="review-card-header">
                        <div class="review-avatar">@review.UserName[..1].ToUpper()</div>
                        <div>
                            <div class="review-username">@review.UserName</div>
                            <div class="review-date">@review.CreatedAt.ToString("dd MMM yyyy")</div>
                        </div>
                        <div class="review-rating-badge @GetRatingClass(review.Rating)" style="margin-left:auto;">
                            <i class="bi bi-star-fill"></i> @review.Rating/10
                        </div>
                    </div>
                    <p class="review-content">@review.Content</p>
                </div>
            }
        </div>
    }
    else if (userReview == null)
    {
        <div style="text-align:center;padding:2rem 0;color:var(--text-muted);font-size:0.85rem;">
            <i class="bi bi-chat-square" style="font-size:1.6rem;display:block;margin-bottom:0.5rem;opacity:0.4;"></i>
            Henüz yorum yok. İlk yorumu sen yaz!
        </div>
    }
</div>

@functions {
    string GetRatingClass(double v) => v switch {
        >= 9 => "rating-high",
        >= 7 => "rating-good",
        >= 5 => "rating-avg",
        >= 4 => "rating-poor",
        > 0  => "rating-bad",
        _    => "rating-unknown"
    };
}

@section Scripts {
<script>
(async function() {
    try {
        const resp = await fetch('/Watchlist/IsInList?movieId=@Model.Id');
        const data = await resp.json();
        if (data.inList) setWlState(true);
    } catch {}
})();

function setWlState(inList) {
    const btn = document.getElementById('wl-toggle-btn');
    if (!btn) return;
    if (inList) {
        btn.className = 'btn-accent';
        document.getElementById('wl-icon').className = 'bi bi-bookmark-fill';
        document.getElementById('wl-text').textContent = 'İzleme Listesinde';
    } else {
        btn.className = 'btn-outline-accent';
        document.getElementById('wl-icon').className = 'bi bi-bookmark';
        document.getElementById('wl-text').textContent = 'İzleme Listesine Ekle';
    }
}

async function toggleDetailsWl() {
    const btn = document.getElementById('wl-toggle-btn');
    const inList = btn.classList.contains('btn-accent');
    const csrf = document.querySelector('#__csrf input[name="__RequestVerificationToken"]').value;
    const fd = new FormData();
    fd.append('__RequestVerificationToken', csrf);
    fd.append('movieId', '@Model.Id');
    if (!inList) {
        fd.append('movieTitle', @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Title ?? "")));
        fd.append('moviePoster', '@(Model.Poster ?? "")');
        fd.append('movieYear', '@(DateTime.TryParse(Model.ReleaseDate, out var yd) ? yd.Year.ToString() : "")');
    }
    const url = inList ? '/Watchlist/Remove' : '/Watchlist/Add';
    const resp = await fetch(url, { method: 'POST', headers: { 'X-Requested-With': 'XMLHttpRequest' }, body: fd });
    if (resp.ok) setWlState(!inList);
}
</script>
}
