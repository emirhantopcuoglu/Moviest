@model IEnumerable<Moviest.Models.Movie>
    @{
    Layout = "~/Views/Shared/SideNavbarLayout.cshtml";
    var query = ViewBag.Query as string;
    }

    <h1 class="modern-title">"@query" ile ilgili Sonuçlar</h1>

    @if (!Model.Any())
    {
    <div class="alert alert-warning d-flex align-items-center p-4 rounded-3 shadow-sm" role="alert">
        <i class="bi bi-exclamation-circle me-3 fs-3"></i>
        <div>
            <h5 class="fw-bold mb-1">Sonuç Bulunamadı</h5>
            <p class="mb-0">Arama kriterlerinize uygun bir film bulunamadı. Lütfen başka bir arama yapmayı deneyin.</p>
        </div>
    </div>
    }

    else
    {
    <div class="d-flex justify-content-between mb-3">
        <a href="@Url.Action("Search", "Movies" , new { query=query, page=(ViewBag.CurrentPage - 1) })"
            class="btn btn-primary @(ViewBag.CurrentPage <= 1 ? " disabled" : "" )">
            &larr; Önceki
        </a>
        <a href="@Url.Action("Search", "Movies" , new { query=query, page=(ViewBag.CurrentPage + 1) })"
            class="btn btn-primary @(ViewBag.CurrentPage >= ViewBag.TotalPages ? " disabled" : "" )">
            Sonraki &rarr;
        </a>
    </div>

    <div class="container">
        <div class="row g-4">
            @foreach (var movie in Model)
            {
            <div class="col-md-3">
                <div class="card h-100 shadow-lg rounded-lg border-0">

                    <img src="@(string.IsNullOrEmpty(movie.Poster) 
                                ? " https://via.placeholder.com/500x750?text=No+Image" :
                        $"https://image.tmdb.org/t/p/w500{movie.Poster}")" class="card-img-top rounded-top"
                        alt="@movie.Title">

                    <div class="card-body">
                        <h5 class="card-title text-truncate">@movie.Title</h5>

                        <p class="card-text text-muted small mb-1">
                            <i class="bi bi-calendar"></i>
                            @(DateTime.TryParse(movie.ReleaseDate, out var parsedDate)
                            ? parsedDate.ToString("yyyy")
                            : "-")
                        </p>
                    </div>

                    <div class="card-footer bg-transparent d-flex justify-content-between align-items-center">

                        <span class="rating-tag @GetRatingClass(movie.VoteAverage)">
                            <i class="bi bi-star-fill">
                                @movie.VoteAverage.ToString("F1")
                            </i>
                        </span>

                        <a href="@Url.Action("Details", "Movies" , new { id=movie.Id })"
                            class="btn btn-outline-primary btn-sm rounded-pill">Detaylar</a>
                    </div>
                </div>
            </div>
            }
        </div>
    </div>
    }

    <div class="d-flex justify-content-between mt-3">
        <a href="@Url.Action("Search", "Movies" , new { query=query, page=(ViewBag.CurrentPage - 1) })"
            class="btn btn-primary @(ViewBag.CurrentPage <= 1 ? " disabled" : "" )">
            &larr; Önceki
        </a>
        <a href="@Url.Action("Search", "Movies" , new { query=query, page=(ViewBag.CurrentPage + 1) })"
            class="btn btn-primary @(ViewBag.CurrentPage >= ViewBag.TotalPages ? " disabled" : "" )">
            Sonraki &rarr;
        </a>
    </div>

    @functions {
    private string GetRatingClass(double vote)
    {
        if (vote >= 9) return "rating-high";
        if (vote >= 7) return "rating-good";
        if (vote >= 5) return "rating-average";
        if (vote >= 4) return "rating-poor";
        return "rating-bad";
        }
    }
    <link href="/css/custom.css" rel="stylesheet">